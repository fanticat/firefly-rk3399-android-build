# Android core
CONFIG_ANDROID=y
CONFIG_ANDROID_BINDER_IPC=y
CONFIG_ANDROID_BINDERFS=y
CONFIG_ANDROID_BINDER_DEVICES="binder,hwbinder,vndbinder"
CONFIG_ASHMEM=y

# SELinux (required by Android init)
# Dependencies: SECURITY_NETWORK, AUDIT, NET, INET
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y
CONFIG_SECURITY_SELINUX=y
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_ENABLE_DEVELOP=y
CONFIG_DEFAULT_SECURITY_SELINUX=y
CONFIG_LSM="lockdown,yama,selinux,bpf"
CONFIG_SECURITY_NETWORK=y
CONFIG_SECURITYFS=y
CONFIG_SECURITY=y

# Android debug filesystem
CONFIG_DEBUG_FS=y

# Required for Android dynamic partitions
CONFIG_BLK_DEV_LOOP=y
CONFIG_DM_VERITY=y
CONFIG_DM_SNAPSHOT=y
CONFIG_DM_UEVENT=y
CONFIG_DM_ZERO=y
CONFIG_MD=y
CONFIG_BLK_DEV_DM=y

# pstore for ramoops
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_RAM=y

# f2fs (Android filesystem)
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_SECURITY=y

# ext4
CONFIG_EXT4_FS=y
CONFIG_EXT4_FS_SECURITY=y

# tmpfs for Android
CONFIG_TMPFS=y

# Required for Android init
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y

# crypto for Android
CONFIG_CRYPTO_SHA256=y
CONFIG_CRYPTO_SHA512=y
CONFIG_CRYPTO_AES=y
